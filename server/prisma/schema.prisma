generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  AGENT
  ADMIN
}

enum PropertyStatus {
  AVAILABLE
  BOOKED
  SOLD
}

enum BookingStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum TransactionStatus {
  INITIATED
  COMPLETED
  FAILED
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String
  email         String    @unique
  password      String
  role          Role      @default(USER)
  phone         String?
  avatar        String?
  isActive      Boolean   @default(true)
  properties    Property[]
  bookings      Booking[]
  reviews       Review[]
  blogs         Blog[]
  transactions  Transaction[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Indexes
  @@index([role])
  @@index([isActive])
  @@index([createdAt(sort: Desc)])
}

model Property {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  description   String
  price         Float
  location      String
  city          String
  area          String
  bhk           Int
  size          Int
  type          String          // Apartment, Villa, Commercial, etc.
  images        String[]
  amenities     String[]
  status        PropertyStatus  @default(AVAILABLE)
  isFeatured    Boolean         @default(false)
  agentId       String          @db.ObjectId
  agent         User            @relation(fields: [agentId], references: [id])
  bookings      Booking[]
  reviews       Review[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Indexes for faster queries
  @@index([status])
  @@index([isFeatured])
  @@index([type])
  @@index([city])
  @@index([price(sort: Asc)])
  @@index([createdAt(sort: Desc)])
  @@index([agentId])
}

model Booking {
  id              String        @id @default(auto()) @map("_id") @db.ObjectId
  userId          String        @db.ObjectId
  user            User          @relation(fields: [userId], references: [id])
  propertyId      String        @db.ObjectId
  property        Property      @relation(fields: [propertyId], references: [id])
  amount          Float
  status          BookingStatus @default(PENDING)
  paymentStatus   String        @default("UNPAID")
  paymentMethod   String?
  paymentDate     DateTime?
  transactionId   String?
  visitDate       DateTime?
  transactions    Transaction[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  bKashTrxId      String?
  bKashPaymentID  String?

  // Indexes
  @@index([status])
  @@index([paymentStatus])
  @@index([userId])
  @@index([propertyId])
  @@index([createdAt(sort: Desc)])
}

model Transaction {
  id            String            @id @default(auto()) @map("_id") @db.ObjectId
  bookingId     String            @db.ObjectId
  booking       Booking           @relation(fields: [bookingId], references: [id])
  userId        String            @db.ObjectId
  user          User              @relation(fields: [userId], references: [id])
  amount        Float
  method        String
  status        TransactionStatus @default(INITIATED)
  trxId         String?           @unique
  paymentId     String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  // Indexes
  @@index([status])
  @@index([userId])
  @@index([bookingId])
  @@index([createdAt(sort: Desc)])
}

model Review {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  user        User      @relation(fields: [userId], references: [id])
  propertyId  String    @db.ObjectId
  property    Property  @relation(fields: [propertyId], references: [id])
  rating      Int
  comment     String
  createdAt   DateTime  @default(now())

  // Indexes
  @@index([propertyId])
  @@index([userId])
  @@index([createdAt(sort: Desc)])
}

model Blog {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String    @unique
  content     String
  coverImage  String
  isPublished Boolean   @default(true)
  authorId    String    @db.ObjectId
  author      User      @relation(fields: [authorId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Indexes
  @@index([isPublished])
  @@index([createdAt(sort: Desc)])
  @@index([authorId])
}

model Contact {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String
  subject   String
  message   String
  reply     String?
  repliedAt DateTime?
  isRead    Boolean  @default(false)
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Indexes for faster queries
  @@index([createdAt(sort: Desc)])
  @@index([isRead])
  @@index([status])
  @@index([email])
}

model Settings {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  siteName      String   @default("LuxeSpace")
  logoUrl       String?
  faviconUrl    String?
  supportEmail String?
  bkashTrxId   String?
  heroVideos   String[]  // Hero section background videos
  heroTitle    String?   // Hero section title
  heroSubtitle String?   // Hero section subtitle
  sliderInterval Int    @default(8)     // Slider auto-slide interval in seconds
  sliderAutoPlay Boolean @default(true) // Auto-play videos
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
